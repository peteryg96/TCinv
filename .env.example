# ============================================
# MongoDB Configuration
# ============================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=password123
MONGO_DB=inventory

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=5000

# Application Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production
SESSION_SECRET=your_session_secret_change_this_in_production

# ============================================
# Shopee API Configuration
# ============================================

# Environment: 'test' or 'production'
SHOPEE_ENV=test

# --- TEST ENVIRONMENT ---
# Get these from: https://partner.test-stable.shopeemobile.com/
SHOPEE_TEST_PARTNER_ID=
SHOPEE_TEST_PARTNER_KEY=
SHOPEE_TEST_SHOP_ID=
SHOPEE_TEST_MERCHANT_ID=
SHOPEE_TEST_API_URL=https://partner.test-stable.shopeemobile.com

# --- PRODUCTION ENVIRONMENT ---
# Get these from: https://partner.shopeemobile.com/
SHOPEE_PROD_PARTNER_ID=
SHOPEE_PROD_PARTNER_KEY=
SHOPEE_PROD_SHOP_ID=
SHOPEE_PROD_MERCHANT_ID=
SHOPEE_PROD_API_URL=https://partner.shopeemobile.com

# Shopee OAuth (if using OAuth 2.0 flow)
SHOPEE_REDIRECT_URL=http://localhost:5000/api/shopee/auth/callback

# Shopee Webhook Configuration
SHOPEE_WEBHOOK_SECRET=
SHOPEE_WEBHOOK_URL=http://localhost:5000/api/shopee/webhook

# ============================================
# Future Platform Integrations
# ============================================

# --- LAZADA ---
LAZADA_ENV=test
# Test Environment
LAZADA_TEST_APP_KEY=
LAZADA_TEST_APP_SECRET=
LAZADA_TEST_API_URL=https://api-pre.lazada.com/rest
# Production Environment
LAZADA_PROD_APP_KEY=
LAZADA_PROD_APP_SECRET=
LAZADA_PROD_API_URL=https://api.lazada.com/rest

# --- TIKTOK SHOP ---
TIKTOK_ENV=test
# Test Environment
TIKTOK_TEST_APP_KEY=
TIKTOK_TEST_APP_SECRET=
TIKTOK_TEST_API_URL=https://open-api-sandbox.tiktokglobalshop.com
# Production Environment
TIKTOK_PROD_APP_KEY=
TIKTOK_PROD_APP_SECRET=
TIKTOK_PROD_API_URL=https://open-api.tiktokglobalshop.com

# ============================================
# ERPNext Integration (Optional)
# ============================================
ERPNEXT_ENABLED=false
ERPNEXT_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ============================================
# Email Configuration (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info
SENTRY_DSN=

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ============================================
# Security - Delete Confirmation
# ============================================
DELETE_PASSWORD=your_secure_password_here
